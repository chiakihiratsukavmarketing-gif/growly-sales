# Growly Sales - 環境変数テンプレート

# .env は git にコミットしない（.gitignore 対象）

# コピー: cp .env.example .env



# --- 外部API（Phase 17: 営業候補取得のみ・送信とは無関係）---

# 本番接続には API_PRODUCTION_ENABLED=true が必須

# external-fetch は FETCH_CANDIDATES 確認入力も必須

API_PRODUCTION_ENABLED=

GOOGLE_PLACES_API_KEY=

WEB_SEARCH_API_KEY=

WEB_SEARCH_ENGINE_ID=



# --- OpenAI（未使用）---

OPENAI_API_KEY=

GOOGLE_SHEETS_CREDENTIALS_PATH=



# --- Gmail下書き作成のみ（Phase 16）---

# 送信API（drafts.send / messages.send）は使用しません。

# refresh token 取得: npm run growly-sales:gmail-oauth-helper（.env は手動編集）

# いずれかの方式で設定:

#

# 方式A: 個別環境変数

GMAIL_CLIENT_ID=

GMAIL_CLIENT_SECRET=

GMAIL_REFRESH_TOKEN=

# 1回の gmail-create-drafts で作成する下書き数の上限（未設定=制限なし）。例: 1

GMAIL_DRAFT_CREATE_LIMIT=

# 営業メール送信元（Gmail下書き From / Reply-To / 署名 Email）
# 未設定時は c_hiratsuka@wantreach.jp
# 下書き作成前に Gmail settings.sendAs で利用可能か確認されます

OUTREACH_FROM_EMAIL=

OUTREACH_REPLY_TO_EMAIL=

OUTREACH_SIGNATURE_EMAIL=

OUTREACH_FROM_DISPLAY_NAME=

#

# 方式B: OAuth JSON ファイルパス（client_id, client_secret, refresh_token を含む）

GMAIL_CREDENTIALS_PATH=

